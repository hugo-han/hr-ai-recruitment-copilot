# 后端环境变量示例（请复制为 .env 并填入真实值；.env 不入库）
# ===== 应用 =====
APP_NAME=hr-ai-recruitment-copilot
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-in-prod

# ===== 数据库（华为云 RDS for PostgreSQL）=====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hr_copilot

# ===== Redis（华为云 DCS）=====
REDIS_URL=redis://localhost:6379/0

# ===== JWT =====
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ===== 对象存储（华为云 OBS）=====
OBS_ACCESS_KEY=
OBS_SECRET_KEY=
OBS_ENDPOINT=
OBS_BUCKET=hr-copilot-resume

# ===== LLM（华为云盘古）=====
LLM_PROVIDER=huawei
LLM_HUAWEI_AK=
LLM_HUAWEI_SK=
LLM_HUAWEI_ENDPOINT=
LLM_HUAWEI_REGION=cn-north-4
LLM_MODEL=pangu-default
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
